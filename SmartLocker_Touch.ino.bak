/* ================= WIFI ================= */
#define WIFI_SSID     "Sarthak_Raut"
#define WIFI_PASSWORD "qwertyuiop"

/* ================= FIREBASE ================= */
#define FIREBASE_HOST "asep-smart-locker-default-rtdb.asia-southeast1.firebasedatabase.app"
#define FIREBASE_SECRET "ehwg3KYlrxk8jVP5wOQcX4YUZ66IZ1h1aHme2Uu"

/* ================= LOCKER CONFIGURATION ================= */
#define LOCKER_ID     "4"   

/* ================= HARDWARE ================= */
#define LOCK_PIN 21
#define UNLOCK_TIME 3000

/* ================= TFT DISPLAY ================= */
#define TFT_CS    5
#define TFT_DC    2
#define TFT_RST   4
// SCK=18, MOSI=23, MISO=19 (Default VSPI)

/* ================= TOUCH SCREEN ================= */
#define TOUCH_CS  15
#define TOUCH_IRQ 27
// T_CLK=18, T_DIN=23, T_DO=19 (Same as TFT)

/* ================= KEYPAD UI SETTINGS ================= */
#define KEYPAD_Y_START 160
#define KEYPAD_HEIGHT  160
#define KEYPAD_WIDTH   240
#define BTN_W (KEYPAD_WIDTH / 3) // 80
#define BTN_H (KEYPAD_HEIGHT / 4) // 40

// Touch Calibration (Adjust these if touches are inaccurate)
#define TS_MINX 300
#define TS_MAXX 3800
#define TS_MINY 300
#define TS_MAXY 3800

/* ================= STATE ================= */
enum LockerState { LOCKED, UNLOCKED };
LockerState state = LOCKED;
String enteredPIN = "";
unsigned long unlockStart = 0;
unsigned long lastQrUpdate = 0;
const unsigned long QR_UPDATE_INTERVAL = 300000; // 5 minutes

// State Management
String currentBackendStatus = "AVAILABLE";
unsigned long long currentSessionEnd = 0; // Epoch milliseconds from Firebase
int currentUnlockCount = 0;
unsigned long lastFirebasePoll = 0;
const unsigned long POLL_INTERVAL = 3000; // Check every 3 seconds

// Display State
enum DisplayMode { DISP_QR, DISP_INFO };
DisplayMode currentDisplayMode = DISP_QR;
bool forceRedraw = true;

// Early Termination State
bool terminationMode = false;
String terminationPIN = "";

// Debug Globals
long debugDuration = 0;
long long debugStartTime = 0;

/* ================= TIME ================= */
const long  gmtOffset_sec = 0; // Set to 0 to force UTC (matches Firebase)
const int   daylightOffset_sec = 0;

/* ================= OBJECTS ================= */
Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_DC, TFT_RST);
XPT2046_Touchscreen ts(TOUCH_CS, TOUCH_IRQ);

uint8_t qrcode[qrcodegen_BUFFER_LEN_MAX];
uint8_t tempBuffer[qrcodegen_BUFFER_LEN_MAX];

/* ================= TFT COLORS ================= */
#define BG_COLOR   ST77XX_BLACK
#define TEXT_COLOR ST77XX_WHITE
#define QR_BG      ST77XX_WHITE
#define QR_FG      ST77XX_BLACK
#define INFO_COLOR ST77XX_GREEN
#define WARN_COLOR ST77XX_WHITE
#define ERROR_COLOR ST77XX_CYAN // Inverted: Cyan->Red
#define BTN_COLOR   0x52AA      // Dark Grey/Blueish
#define BTN_TEXT    ST77XX_WHITE

/* ================= FORWARD DECLARATIONS ================= */
void centerText(const char* text, int y, int size, uint16_t color);
void displayQRCode(const char* text, int yPos, int maxScale);
void drawQRMode();
void drawInfoMode();
void drawPinState();
void drawTerminationMode();
void pollLockerStatus();
void handleTouchKeypad();
void checkPIN();
void checkTerminationPIN();
void terminateSession();
void unlockLocker();
void handleAutoLock();
void checkSessionExpiration();
// UI Helpers
void drawKeypad();
char getTouchKey();

/* ================= SETUP ================= */
void setup() {
  Serial.begin(115200);
  delay(1000);
  
  // 1. PIN SAFETY: Explicitly set CS pins HIGH to disable SPI devices initially
  // This prevents the Touch controller from interfering with TFT initialization
  pinMode(TFT_CS, OUTPUT);
  digitalWrite(TFT_CS, HIGH); 
  
  pinMode(TOUCH_CS, OUTPUT);
  digitalWrite(TOUCH_CS, HIGH);

  // 2. Hardware Init
  pinMode(LOCK_PIN, OUTPUT);
  digitalWrite(LOCK_PIN, LOW); // Locked
  
  // 3. SPI BUS Init (Explicitly defines global SPI pins)
  // SCK=18, MISO=19, MOSI=23, SS=5
  SPI.begin(18, 19, 23, 5);
  
  // 4. TFT Init
  // Manual Reset to ensure clean state
  pinMode(TFT_RST, OUTPUT);
  digitalWrite(TFT_RST, HIGH);
  delay(100);
  digitalWrite(TFT_RST, LOW);
  delay(100);
  digitalWrite(TFT_RST, HIGH);
  delay(200);

  tft.init(240, 320); 
  tft.setRotation(2);
  tft.invertDisplay(true); // Try removing this if colors are inverted (White screen usually means no-init, but check this)
  tft.fillScreen(BG_COLOR);
  
  // 5. Touch Init (After TFT is established)
  // DISABLE TOUCH TEMPORARILY TO DEBUG DISPLAY
  // ts.begin();
  // ts.setRotation(2); // Match TFT Rotation
  
  // Force Touch CS HIGH to silence it completely
  digitalWrite(TOUCH_CS, HIGH); 
  
  // Set safe SPI speed for Breadboard wiring
  tft.setSPISpeed(20000000); // 20 MHz

  centerText("Connecting...", 150, 2, TEXT_COLOR);
  
  // WiFi
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int w = 0;
  while (WiFi.status() != WL_CONNECTED && w < 20) { 
    delay(200); 
    w++; 
  }
  
  centerText("Connected!", 150, 2, INFO_COLOR);
  delay(1000);
  
  // Time Sync
  configTime(gmtOffset_sec, daylightOffset_sec, "pool.ntp.org", "time.nist.gov");
  centerText("Syncing Time...", 180, 2, TEXT_COLOR);
  
  time_t now = time(NULL);
  // Wait a bit for time to sync
  unsigned long tStart = millis();
  while (now < 24 * 3600 && millis() - tStart < 5000) { 
    delay(100);
    now = time(NULL);
  }
  
  // Initial Fetch
  pollLockerStatus();
  forceRedraw = true; 
}

/* ================= LOOP ================= */
void loop() {
  // 1. PIN & Lock Logic
  if (state == LOCKED) {
    // Only handle keypad if we are in a mode that needs it (INFO or TERMINATION)
    // In QR mode (AVAILABLE), keypad is not shown usually, but if needed we can enable it.
    // However, original logic ran handleKeypad() always in LOCKED state.
    // We will only process touch if the keypad is actually drawn (Active or Termination).
    if (currentDisplayMode == DISP_INFO || terminationMode) {
      handleTouchKeypad();
    }
  } else {
    handleAutoLock();
  }

  // 1.5 Check Expiration locally
  checkSessionExpiration();
  
  // 2. Poll Firebase (Non-blocking)
  if (millis() - lastFirebasePoll >= POLL_INTERVAL) {
    pollLockerStatus();
    lastFirebasePoll = millis();
  }
  
  // 3. UI Updates
  if (state == LOCKED) { 
    if (terminationMode) {
      static unsigned long lastTerminationDraw = 0;
      if (forceRedraw || millis() - lastTerminationDraw >= 1000) {
        drawTerminationMode();
        lastTerminationDraw = millis();
      }
    } else if (currentDisplayMode == DISP_QR) {
      if (forceRedraw || millis() - lastQrUpdate >= QR_UPDATE_INTERVAL) {
        drawQRMode();
      }
    } else {
      // Info Mode (Timer)
      static unsigned long lastTimerDraw = 0;
      if (forceRedraw || millis() - lastTimerDraw >= 1000) {
        drawInfoMode();
        lastTimerDraw = millis();
      }
    }
  }
}

/* ================= IMPLEMENTATIONS ================= */

void centerText(const char* text, int y, int size, uint16_t color) {
  tft.setTextSize(size);
  tft.setTextColor(color, BG_COLOR); 
  int16_t x1, y1;
  uint16_t w, h;
  tft.getTextBounds(text, 0, 0, &x1, &y1, &w, &h);
  int x = (tft.width() - w) / 2;
  tft.setCursor(x, y);
  tft.print(text);
}

void displayQRCode(const char* text, int yPos, int maxScale) {
  bool ok = qrcodegen_encodeText(text, tempBuffer, qrcode, qrcodegen_Ecc_LOW,
                                 qrcodegen_VERSION_MIN, qrcodegen_VERSION_MAX,
                                 qrcodegen_Mask_AUTO, true);
  if (ok) {
    int size = qrcodegen_getSize(qrcode);
    int scale = maxScale;
    while ((size * scale) > tft.width() - 20) scale--;
    
    int pxSize = size * scale;
    int x = (tft.width() - pxSize) / 2;
    int margin = 5;
    tft.fillRect(x - margin, yPos - margin, pxSize + (margin * 2), pxSize + (margin * 2), QR_BG);
    
    for (int py = 0; py < size; py++) {
      for (int px = 0; px < size; px++) {
        if (qrcodegen_getModule(qrcode, px, py)) {
          tft.fillRect(x + (px * scale), yPos + (py * scale), scale, scale, QR_FG);
        }
      }
    }
  }
}

// Draw the Virtual Keypad
void drawKeypad() {
  tft.setTextSize(3);
  tft.setTextColor(BTN_TEXT);
  
  // Layout: 4 rows, 3 cols
  // Keys: 1 2 3 / 4 5 6 / 7 8 9 / * 0 #
  char keys[4][3] = {
    {'1','2','3'},
    {'4','5','6'},
    {'7','8','9'},
    {'*','0','#'}
  };

  for(int r=0; r<4; r++) {
    for(int c=0; c<3; c++) {
      int x = c * BTN_W;
      int y = KEYPAD_Y_START + (r * BTN_H);
      
      // Button Outline
      tft.drawRect(x, y, BTN_W, BTN_H, ST77XX_WHITE);
      
      // Determine Text Position
      // Center of button
      int tx = x + (BTN_W / 2) - 9; // Approx offset for Size 3 char
      int ty = y + (BTN_H / 2) - 10;
      
      tft.setCursor(tx, ty);
      tft.print(keys[r][c]);
    }
  }
}

// Map Touch to Key
char getTouchKey() {
  if (!ts.touched()) return 0;
  
  TS_Point p = ts.getPoint();
  
  // Simple debounce: Wait until release? 
  // For better UX, registers on press, then wait for release or hold-off.
  // We'll use a simple hold-off delay in the loop, or 'wait for release' here.
  // Wait for release is safer to avoid multiple chars.
  while (ts.touched()) {
    delay(10);
  }
  
  // Map Raw to Screen Coordinates
  // Note: Check actual calibration on device. 
  // Assuming map mapping is linear.
  int screenX = map(p.x, TS_MINX, TS_MAXX, 0, 240);
  int screenY = map(p.y, TS_MINY, TS_MAXY, 0, 320);
  
  // Check if touch is within Keypad Area
  if (screenY < KEYPAD_Y_START) return 0;
  
  int r = (screenY - KEYPAD_Y_START) / BTN_H;
  int c = screenX / BTN_W;
  
  if (r >= 0 && r < 4 && c >= 0 && c < 3) {
    char keys[4][3] = {
      {'1','2','3'},
      {'4','5','6'},
      {'7','8','9'},
      {'*','0','#'}
    };
    return keys[r][c];
  }
  
  return 0;
}

void drawPinState() {
  // Clear the area where PIN stars will be shown
  // Moved up to Y=120 to fit Keypad
  tft.fillRect(0, 120, 240, 30, BG_COLOR);
  
  if (enteredPIN.length() > 0) {
    String masked = "";
    for (int i = 0; i < enteredPIN.length(); i++) {
      masked += "*";
    }
    centerText(masked.c_str(), 120, 3, TEXT_COLOR);
  }
}

void drawTerminationPinState() {
  // Moved to Y=120
  tft.fillRect(0, 120, 240, 30, BG_COLOR);
  
  if (terminationPIN.length() > 0) {
    String masked = "";
    for (int i = 0; i < terminationPIN.length(); i++) {
      masked += "*";
    }
    centerText(masked.c_str(), 120, 3, TEXT_COLOR);
  }
}

void drawTerminationMode() {
  if (forceRedraw) {
    tft.fillScreen(BG_COLOR);
    
    // Header
    centerText("TERMINATE", 10, 3, WARN_COLOR);
    centerText("SESSION", 40, 3, WARN_COLOR);
    
    // Instructions
    centerText("Enter PIN to confirm", 80, 2, TEXT_COLOR);
    
    // Show Keypad
    drawKeypad();
    
    forceRedraw = false;
  }
  drawTerminationPinState();
}

void drawQRMode() {
  if (forceRedraw) {
    tft.fillScreen(BG_COLOR);
    centerText("Smart Locker", 10, 2, TEXT_COLOR);
    centerText("Scan to book", tft.height() - 40, 2, TEXT_COLOR);
    centerText("locker", tft.height() - 20, 2, TEXT_COLOR);
    forceRedraw = false;
  }
  
  String dynamicURL = "https://smart-locker-system-two.vercel.app/booking.html?id=" + String(LOCKER_ID) + "&t=" + String(millis());
  displayQRCode(dynamicURL.c_str(), 50, 7);
  lastQrUpdate = millis();
}

void drawInfoMode() {
  unsigned long long nowMs = (unsigned long long)time(NULL) * 1000ULL;
  bool showTimer = (currentUnlockCount > 0);
  
  if (forceRedraw) {
    tft.fillScreen(BG_COLOR);
    
    // Header
    centerText("Locker 04", 10, 3, TEXT_COLOR);
    
    if (showTimer) {
        centerText("Expires In:", 50, 2, INFO_COLOR);
    } else {
        centerText("Waiting User", 50, 2, TEXT_COLOR);
    }
    
    // Show Keypad
    drawKeypad();
    drawPinState();
    
    forceRedraw = false;
  }
  
  if (showTimer) {
    long remainingSeconds = 0;
    if (currentSessionEnd > nowMs) {
      remainingSeconds = (long)((currentSessionEnd - nowMs) / 1000);
    }
    if (remainingSeconds < 0) remainingSeconds = 0;
    
    int hours = remainingSeconds / 3600;
    int minutes = (remainingSeconds % 3600) / 60;
    int seconds = remainingSeconds % 60;
    
    char timeStr[16];
    sprintf(timeStr, "%02d:%02d:%02d", hours, minutes, seconds);
    
    // Timer Position Y=80
    centerText(timeStr, 80, 4, TEXT_COLOR);
  }
}

void handleTouchKeypad() {
  char key = getTouchKey();
  if (!key) return;
  
  Serial.print("Touch Key: ");
  Serial.println(key);

  if (terminationMode) {
    if (key >= '0' && key <= '9') {
      terminationPIN += key;
      drawTerminationPinState();
    }
    else if (key == '#') {
      if (terminationPIN.length() > 0) checkTerminationPIN();
      terminationPIN = "";
      drawTerminationPinState();
    }
    else if (key == '*') { // 'C' logic mapped to '*' on NumPad? Or allow 'C' logic if needed. 
       // Original code had 'C' or '*'. Keypad has '*' so we use '*'.
       // Reset Termination
       terminationMode = false;
       terminationPIN = "";
       forceRedraw = true;
    }
    return;
  }
  
  // Normal Mode
  if (key >= '0' && key <= '9') {
    enteredPIN += key;
    drawPinState();
  }
  else if (key == '#') {
    if (enteredPIN.length() > 0) checkPIN();
    else Serial.println("No PIN");
    enteredPIN = "";
    drawPinState();
  }
  else if (key == '*') {
     if (currentBackendStatus == "ACTIVE") {
       terminationMode = true;
       terminationPIN = "";
       forceRedraw = true;
     } else {
       enteredPIN = "";
       drawPinState();
     }
  }
}

void pollLockerStatus() {
  if (WiFi.status() != WL_CONNECTED) return;
  
  HTTPClient http;
  String url = "https://" + String(FIREBASE_HOST) + "/lockers/" + String(LOCKER_ID) + ".json?auth=" + String(FIREBASE_SECRET);
  http.begin(url);
  int httpCode = http.GET();
  String payload = http.getString();
  http.end();

  if (httpCode == 200) {
    StaticJsonDocument<1024> doc;
    deserializeJson(doc, payload); 
    
    const char* st = doc["status"];
    unsigned long long endTs = doc["sessionEnd"].as<unsigned long long>();
    
    if (endTs == 0) {
       long long start = doc["startTime"];
       long duration = doc["duration"]; 
       debugStartTime = start;
       debugDuration = duration;
       if (start > 0 && duration > 0) endTs = (unsigned long long)start + (unsigned long long)duration;
    } else {
       debugStartTime = doc["startTime"] | 0;
       debugDuration = doc["duration"] | 0;
    }
    
    int unlocks = doc["unlockCount"] | 0; 
    String newStatus = st ? String(st) : "AVAILABLE";
    
    if (newStatus != currentBackendStatus || unlocks != currentUnlockCount) {
      if (newStatus != currentBackendStatus) forceRedraw = true;
      if (unlocks != currentUnlockCount && currentBackendStatus == "ACTIVE") forceRedraw = true;
      
      currentBackendStatus = newStatus;
      bool sameSession = ((unsigned long long)endTs == currentSessionEnd);
      if (currentSessionEnd == 0 && endTs > 0) sameSession = true;
      currentSessionEnd = (unsigned long long)endTs;
      
      if (sameSession) {
        if (unlocks > currentUnlockCount) currentUnlockCount = unlocks;
      } else {
        currentUnlockCount = unlocks;
      }
      
      if (currentBackendStatus == "ACTIVE") {
        currentDisplayMode = DISP_INFO;
      } else {
        currentDisplayMode = DISP_QR;
        terminationMode = false;
        terminationPIN = "";
      }
    } else {
      if (currentBackendStatus == "ACTIVE") {
        currentSessionEnd = (unsigned long long)endTs;
        currentUnlockCount = unlocks;
      }
    }
  }
}

void checkPIN() {
  // Logic remains same, visuals adjusted to redraw keypad on fail
  if (WiFi.status() != WL_CONNECTED) return;
  
  HTTPClient http;
  String url = "https://" + String(FIREBASE_HOST) + "/lockers/" + String(LOCKER_ID) + ".json?auth=" + String(FIREBASE_SECRET);
  http.begin(url);
  int httpCode = http.GET();
  String payload = http.getString();
  http.end();
  
  if (httpCode == 200 && payload.length() > 0 && payload != "null") {
    StaticJsonDocument<1024> doc;
    deserializeJson(doc, payload);
    const char* firebasePIN = doc["pin"];
    const char* status = doc["status"];
    
    if (String(status) == "ACTIVE" && enteredPIN == String(firebasePIN)) {
      unsigned long long endTs = doc["sessionEnd"].as<unsigned long long>();
      if (endTs == 0) {
         long long start = doc["startTime"];
         long duration = doc["duration"]; 
         if (start > 0 && duration > 0) endTs = (unsigned long long)start + (unsigned long long)duration;
      }
      currentSessionEnd = endTs;
      currentBackendStatus = "ACTIVE";
      unlockLocker();
    } else {
      tft.fillScreen(BG_COLOR);
      centerText("Wrong PIN", 100, 2, ERROR_COLOR);
      centerText("Try Again", 130, 2, ERROR_COLOR);
      delay(2000);
      forceRedraw = true;
    }
  }
}

void checkTerminationPIN() {
  if (WiFi.status() != WL_CONNECTED) return;
  HTTPClient http;
  String url = "https://" + String(FIREBASE_HOST) + "/lockers/" + String(LOCKER_ID) + ".json?auth=" + String(FIREBASE_SECRET);
  http.begin(url);
  int httpCode = http.GET();
  String payload = http.getString();
  http.end();
  
  if (httpCode == 200 && payload.length() > 0 && payload != "null") {
    StaticJsonDocument<1024> doc;
    deserializeJson(doc, payload);
    const char* firebasePIN = doc["pin"];
    const char* status = doc["status"];
    
    if (String(status) == "ACTIVE" && terminationPIN == String(firebasePIN)) {
      terminateSession();
    } else {
      tft.fillScreen(BG_COLOR);
      centerText("Wrong PIN", 100, 2, ERROR_COLOR);
      delay(2000);
      terminationMode = false;
      terminationPIN = "";
      forceRedraw = true;
    }
  }
}

void terminateSession() {
  if (WiFi.status() == WL_CONNECTED) {
     HTTPClient http;
     String url = "https://" + String(FIREBASE_HOST) + "/lockers/" + String(LOCKER_ID) + ".json?auth=" + String(FIREBASE_SECRET);
     String json = "{\"status\":\"AVAILABLE\",\"pin\":\"\",\"startTime\":0,\"sessionEnd\":0,\"duration\":0,\"unlockCount\":0}";
     http.begin(url);
     http.sendRequest("PATCH", json);
     http.end();
  }
  digitalWrite(LOCK_PIN, LOW);
  state = LOCKED;
  currentBackendStatus = "AVAILABLE";
  currentSessionEnd = 0;
  currentUnlockCount = 0;
  enteredPIN = "";
  terminationPIN = "";
  terminationMode = false;
  debugStartTime = 0;
  debugDuration = 0;
  currentDisplayMode = DISP_QR;
  forceRedraw = true;
  
  tft.fillScreen(BG_COLOR);
  centerText("Session", 100, 2, INFO_COLOR);
  centerText("Terminated", 130, 2, INFO_COLOR);
  delay(2000);
  forceRedraw = true;
}

void unlockLocker() {
  digitalWrite(LOCK_PIN, HIGH);
  unlockStart = millis();
  state = UNLOCKED;
  currentUnlockCount++; 
  forceRedraw = true; 
  
  HTTPClient http;
  String countUrl = "https://" + String(FIREBASE_HOST) + "/lockers/" + String(LOCKER_ID) + "/unlockCount.json?auth=" + String(FIREBASE_SECRET);
  http.begin(countUrl);
  int getCode = http.GET();
  String countPayload = http.getString();
  http.end();
  int currentCount = 0;
  if (getCode == 200 && countPayload != "null") currentCount = countPayload.toInt();
  currentCount++;
  http.begin(countUrl);
  http.PUT(String(currentCount));
  http.end();

  if (debugStartTime == 0) {
     unsigned long long nowUTC = (unsigned long long)time(NULL) * 1000ULL;
     String startUrl = "https://" + String(FIREBASE_HOST) + "/lockers/" + String(LOCKER_ID) + "/startTime.json?auth=" + String(FIREBASE_SECRET);
     http.begin(startUrl);
     http.PUT(String((unsigned long long)nowUTC));
     http.end();
     debugStartTime = nowUTC;
     if (debugDuration > 0) currentSessionEnd = nowUTC + (unsigned long long)debugDuration;
  }
}

void handleAutoLock() {
  if (millis() - unlockStart >= UNLOCK_TIME) {
    digitalWrite(LOCK_PIN, LOW);
    state = LOCKED;
    enteredPIN = "";
  }
}

void checkSessionExpiration() {
  if (currentBackendStatus != "ACTIVE" || currentSessionEnd == 0) return;
  unsigned long long nowMs = (unsigned long long)time(NULL) * 1000ULL;
  if (nowMs > currentSessionEnd) {
    terminateSession(); // Re-use logic for reset
  }
}
